# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI Base URL (for proxy or alternative endpoints)
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Server default model name for OpenAI-compatible local endpoints
LOCAL_MODEL_NAME=

# Server Configuration (Optional)
HOST=0.0.0.0
PORT=8099

# Whisper Model Configuration (Optional)
# Options: tiny, base, small, medium, large
WHISPER_MODEL_SIZE=base
# Docker GPU defaults. Use cpu/int8 to force CPU mode.
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# Runtime cache locations inside Docker. docker-compose.yml persists these with named volumes.
XDG_CACHE_HOME=/app/.cache
HF_HOME=/app/.cache/huggingface
